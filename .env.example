APP_NAME=fitbit-dify-app
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Local default: SQLite stored in backend/app.db
# DATABASE_URL=sqlite:///D:/absolute/path/to/app.db
#
# Supabase (recommended for shared or deployed environments):
# Use the Session Pooler connection string from the Supabase project settings.
# Important: keep the prefix as postgresql:// for SQLAlchemy compatibility.
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY=
DIFY_WORKFLOW_ENDPOINT=/workflows/run
DIFY_RESPONSE_MODE=blocking

# Optional. Relative paths are resolved from the repo root.
MODEL_ARTIFACT_PATH=./data/artifacts/fatigue_v1.json
