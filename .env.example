APP_NAME=fitbit-dify-app
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Optional. If omitted, the app uses backend/app.db automatically.
# DATABASE_URL=sqlite:///D:/absolute/path/to/app.db

DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY=
DIFY_WORKFLOW_ENDPOINT=/workflows/run
DIFY_RESPONSE_MODE=blocking

# Optional. Relative paths are resolved from the repo root.
MODEL_ARTIFACT_PATH=./data/artifacts/fatigue_v1.json
